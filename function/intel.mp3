# =========================
# FINAL DIAGNOSTIC SCRIPT
# =========================
Write-Host "*******************************************************************************************************************"
Write-Host "`n===  USER INFO ===" -ForegroundColor Cyan
Write-Host "User: $(whoami)"
try {
    whoami /user | findstr /i "S"
} catch {
    Write-Host "Field to get info"
}

Write-Host "`nENVIRONMENT VARIABLES:"
Write-Host "USERNAME   = $env:USERNAME"
Write-Host "USERDOMAIN = $env:USERDOMAIN"
Write-Host "USERPROFILE= $env:USERPROFILE"

Write-Host "*******************************************************************************************************************"
Write-Host "`n===  SYSTEM INFO ===" -ForegroundColor Cyan
try {
    systeminfo | findstr /C:"OS Name" /C:"OS Version" /C:"System Type" /C:"System Manufacturer" /C:"System Model"  /C:"Logon Server" /C:"Hyper-V Requirements"
} catch {
    Write-Host "Field to get info"
}

Write-Host "*******************************************************************************************************************"
Write-Host "`n===  NETWORK ===" -ForegroundColor Cyan
$networkInfo = ipconfig | select-string "IPv4","IPv6","Mask","Gateway"
$networkInfo | ForEach-Object {
    $line = $_.Line.Trim()
    if ($line -match '(.+?):\s*(.+)') {
        $name = $matches[1].Trim()
        $value = $matches[2].Trim()
        "{0,-30} {1}" -f $name, $value
    }
}

Write-Host "*******************************************************************************************************************"
Write-Host ""
Write-Host "===  GET-HOTFIX ===" -ForegroundColor Cyan
try {
    $hotfix = get-hotfix
    $hotfix | Format-Table -AutoSize
} catch {
    Write-Host "`nField to get info"
}

Write-Host "*******************************************************************************************************************"
Write-Host "=== DISKS ===" -ForegroundColor Cyan -NoNewline
Write-Host ""
try {
    $disks = Get-WmiObject Win32_LogicalDisk |
        Select-Object DeviceID, VolumeName, 
            @{Name="Free (GB)";Expression={[math]::Round($_.FreeSpace/1GB,2)}},
            @{Name="Total (GB)";Expression={[math]::Round($_.Size/1GB,2)}}
    
    $disks | Format-Table -AutoSize
} catch {
    Write-Host "`nField to get info"
}
Write-Host "*******************************************************************************************************************"
Write-Host "IT'S DONE!!"